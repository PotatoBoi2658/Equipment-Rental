@model List<Equipment_Rental.Models.UserListViewModel>
@{
    ViewData["Title"] = "Управление на потребители";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people"></i> Потребители</h2>
        <a href="/Users/Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Нов потребител</a>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover bg-white border">
            <thead class="table-dark">
                <tr>
                    <th>Потребителско име</th>
                    <th>Имейл</th>
                    <th>Роли</th>
                    <th class="text-center">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td><strong>@user.UserName</strong></td>
                        <td>@user.Email</td>
                        <td>
                            @if (user.Roles.Any())
                            {
                                foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-info text-dark">@role</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">Няма роля</span>
                            }
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/Users/Edit/@user.Id" class="btn btn-outline-secondary">Редактирай</a>
                                <form method="post" action="/Users/Delete" onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този потребител? Всички негови заявки може да бъдат изтрити!');" style="display:inline;">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button class="btn btn-outline-danger">Изтрий</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
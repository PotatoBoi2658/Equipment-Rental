@model Equipment_Rental.Models.EditUserViewModel
@{
    ViewData["Title"] = "Редактиране";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 card shadow p-4">
            <h3 class="mb-4 text-primary">Редактиране на @Model.UserName</h3>
            <form method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label fw-bold">Потребителско име</label>
                    <input asp-for="UserName" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Имейл</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>


                <div class="mb-4 p-3 border rounded bg-light">
                    <label asp-for="NewPassword" class="form-label fw-bold text-danger">Нова парола (Опционално)</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="Въведи само ако искаш да я смениш..." />
                    <small class="text-muted">Ако оставиш полето празно, текущата парола се запазва.</small>
                </div>

                <button type="submit" class="btn btn-warning w-100 mb-2 fw-bold">Запази промените</button>
                <a href="/Users/Index" class="btn btn-light w-100">Отказ</a>
            </form>
        </div>
    </div>
</div>
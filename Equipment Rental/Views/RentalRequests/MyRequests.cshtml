@model List<Equipment_Rental.Models.RentalRequest>
@{
    ViewData["Title"] = "Моите заявки";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-clock-history"></i> Моите заявки за наем</h2>
        <a href="/RentalRequests/Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Нова заявка
        </a>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-light border text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
            <p class="mt-3 text-muted">Все още нямате направени заявки.</p>
            <a href="/Equipment/Index" class="btn btn-outline-primary btn-sm">Разгледай оборудването</a>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white">
                <thead class="table-light">
                    <tr>
                        <th>Статус</th>
                        <th>Период на наемане</th>
                        <th>Избрано оборудване</th>
                        <th class="text-center">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                @{
                                    var statusClass = r.Status == "Approved" ? "bg-success" :
                                                     r.Status == "Pending" ? "bg-warning text-dark" : "bg-danger";
                                }
                                <span class="badge @statusClass" style="min-width: 80px;">
                                    @(r.Status == "Approved" ? "Одобрена" : r.Status == "Pending" ? "Чакаща" : "Отказана")
                                </span>
                            </td>
                            <td>
                                <div class="small text-muted">
                                    <i class="bi bi-calendar-event"></i> @r.StartDate.ToShortDateString() — @r.EndDate.ToShortDateString()
                                </div>
                                @if (!string.IsNullOrEmpty(r.Purpose))
                                {
                                    <div class="text-truncate" style="max-width: 200px;" title="@r.Purpose">
                                        <small><strong>Цел:</strong> @r.Purpose</small>
                                    </div>
                                }
                            </td>
                            <td>
                                @foreach (var i in r.Items)
                                {
                                    <div class="badge border text-dark fw-normal mb-1">
                                        <i class="bi bi-box"></i> @(i.EquipmentItem?.Name ?? "Продукт") <span class="text-primary font-monospace">x@(i.Quantity)</span>
                                    </div>
                                }
                            </td>
                            <td class="text-center">
                                @if (r.Status == "Pending")
                                {
                                    <form method="post" action="/RentalRequests/Delete" onsubmit="return confirm('Сигурни ли сте, че искате да отмените заявката?');">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Отмени
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small italic">Приключена</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
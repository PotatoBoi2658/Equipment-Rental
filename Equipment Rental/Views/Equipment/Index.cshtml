@model List<Equipment_Rental.Models.EquipmentItem>
@{
    ViewData["Title"] = "Каталог Оборудване";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-tools"></i> Налично оборудване</h2>
        @if (User.IsInRole("Admin"))
        {
            <a class="btn btn-primary" href="/Equipment/Create">
                <i class="bi bi-plus-circle"></i> Добави нов продукт
            </a>
        }
    </div>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-4">
            <input name="search" class="form-control" placeholder="Търси по име..." value="@Context.Request.Query["search"]" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary">Търси</button>
        </div>
    </form>

    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">Няма намерено оборудване по тези критерии.</p>
            </div>
        }
        else
        {
            foreach (var item in Model)
            {
                <div class="col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div style="height: 200px; overflow: hidden; background: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="object-fit: cover; height: 100%; width: 100%;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                    <i class="bi bi-image" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text text-muted small flex-grow-1">
                                @(item.Description?.Length > 100 ? item.Description.Substring(0, 97) + "..." : item.Description)
                            </p>
                            
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="badge bg-info text-dark">Налично: @item.QuantityAvailable</span>
                                <span class="badge @(item.Condition == "New" ? "bg-success" : "bg-warning text-dark")">@item.Condition</span>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-top-0 d-grid gap-2">
                            @if (User.IsInRole("Admin"))
                            {
                                <div class="btn-group w-100">
                                    <a href="/Equipment/Edit/@item.Id" class="btn btn-sm btn-outline-secondary">Редактирай</a>
                                    <form method="post" action="/Equipment/Delete" onsubmit="return confirm('Сигурни ли сте?');" style="display:inline;">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-outline-danger">Изтрий</button>
                                    </form>
                                </div>
                            }
                            <a href="/RentalRequests/Create" class="btn btn-primary btn-sm @(item.QuantityAvailable <= 0 ? "disabled" : "")">
                                <i class="bi bi-cart-plus"></i> Наеми
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>